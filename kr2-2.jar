public static String removeVowelsManual(String str) {
    String vowels = "aeiouAEIOU–į–Ķ—Ď–ł–ĺ—É—č—ć—é—Ź–ź–ē–Ā–ė–ě–£–ę–≠–ģ–Į";
    StringBuilder result = new StringBuilder();
    
    for (int i = 0; i < str.length(); i++) {
        char c = str.charAt(i);
        if (vowels.indexOf(c) == -1) {
            result.append(c);
        }
    }
    return result.toString();
}